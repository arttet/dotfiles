{
  "lineWidth": 120,
  "indentWidth": 2,
  "useTabs": false,
  "newLineKind": "lf",
  "markdown": {
    "textWrap": "maintain"
  },
  "excludes": [
    "**/node_modules",
    "**/*-lock.json",
    "**/lazy-lock.json",
    "docs/bun.lock",
    "docs/.vitepress/cache",
    "docs/.vitepress/dist",
    "vendir.lock.yml",
    ".dotter",
    "dotfiles/.config/alacritty/themes/themes",
    "dotfiles/.config/yazi/flavors",
    "dotfiles/.config/yazi/plugins"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.22.1.wasm",
    "https://plugins.dprint.dev/typescript-0.96.1.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
  ]
}
