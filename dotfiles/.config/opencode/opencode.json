{
  "$schema": "https://opencode.ai/config.json",

  "model": "kimi-for-coding/k2p7",
  "small_model": "kimi-for-coding/k2p6",
  "default_agent": "plan",

  "autoupdate": false,

  "shell": "bash",

  "server": {
    "port": 4096
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },

  "watcher": {
    "ignore": [
      ".cache/**",
      ".direnv/**",
      ".git/**",
      ".next/**",
      ".turbo/**",
      ".venv/**",
      "__pycache__/**",
      "build/**",
      "coverage/**",
      "dist/**",
      "node_modules/**",
      "target/**"
    ]
  },

  "instructions": [
    "AGENTS.md"
  ],

  "mcp": {
    "serena": {
      "type": "local",
      "enabled": true,
      "command": [
        "uvx",
        "serena-agent@v1.5.3",
        "start-mcp-server",
        "--context",
        "agent",
        "--project-from-cwd",
        "--open-web-dashboard=false"
      ],
      "environment": {
        "PYTHONUNBUFFERED": "1"
      },
      "timeout": 30000
    }
  },

  "permission": {
    "*": "ask",

    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.netrc": "deny",
      "*id_rsa*": "deny",
      "*id_ed25519*": "deny",
      "*ssh/*": "deny",
      "*gnupg/*": "deny",
      "*history*": "deny",
      "*kube/config": "deny",
      "*.env.example": "allow"
    },

    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "skill": "allow",

    "edit": "ask",
    "write": "ask",
    "webfetch": "ask",
    "websearch": "allow",
    "question": "allow",
    "doom_loop": "ask",
    "external_directory": "ask",

    "bash": {
      "*": "ask",

      "pwd": "allow",
      "eza *": "allow",
      "fd *": "allow",
      "rg *": "allow",
      "bat *": "allow",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git remote*": "allow",
      "git stash*": "allow",
      "git worktree list": "allow",

      "gh pr view*": "allow",
      "gh pr list*": "allow",
      "gh pr diff*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",

      "just fmt*": "allow",
      "just lint*": "allow",
      "just build*": "allow",
      "just test*": "allow",

      "ls *": "deny",
      "find *": "deny",
      "grep *": "deny",
      "cat *": "deny",

      "git branch*": "deny",
      "git fetch*": "deny",
      "git pull*": "deny",
      "git push*": "deny",
      "git revert*": "deny",

      "sudo*": "deny",
      "rm -rf *": "deny",
      "mkfs*": "deny",
      "dd *": "deny",
      "chmod -R 777*": "deny",
      "chown -R *": "deny",
      "curl *|*sh*": "deny",
      "wget *|*sh*": "deny"
    }
  }
}
