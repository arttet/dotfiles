#!/usr/bin/env sh
set -eu

file=${1:-}
line=${2:-}

case "$line" in
  '' | *[!0-9]*)
    line=1
    ;;
esac

if [ -z "$file" ] || [ ! -e "$file" ]; then
  exit 0
fi

ignore_revs_file=$(git config --get blame.ignoreRevsFile || true)

if [ -n "$ignore_revs_file" ] && [ ! -e "$ignore_revs_file" ]; then
  git blame --no-ignore-revs-file -L "$line,+1" -- "$file"
else
  git blame -L "$line,+1" -- "$file"
fi
